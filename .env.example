# VibeSwarm environment — consumed, NOT owned by this repo.
# Ansible (Dislace/ansible) templates the real .env from vault.
# Copy to .env for local/manual runs.

# Cloudflare Tunnel token (from `cloudflared tunnel token <name>` or the
# Zero Trust dashboard). cloudflared uses this as its sole credential.
VSWARM_TUNNEL_TOKEN=

# Optional: container image registry prefix for pushing/pulling the
# workspace image (e.g. ghcr.io/dislace). Leave blank to build locally.
VSWARM_REGISTRY=

# Compose project name (namespaces all resources). Default: vswarm.
COMPOSE_PROJECT_NAME=vswarm
