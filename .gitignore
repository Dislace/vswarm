# --- VibeSwarm: never commit runtime state or secrets ---

# Real deployment config (Ansible templates these from vault; repo ships only *.example)
/tenants.yaml
/.env

# Rendered artifacts (contain per-tenant T3 bearer tokens — treat as secret)
/generated/

# Per-tenant runtime state: repos, SSH keys, agent/API config
/config/
**/.ssh/
**/repos/

# Any stray token/secret files
*.token
*.pem
*.key
secrets/

# Go build output
/vswarm
/dist/
*.test
*.out

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
