# GENERATED by `vswarm render` — DO NOT EDIT. Edit tenants.yaml instead.

networks:
  vswarm-edge:
    name: vswarm-edge
{{- if .EdgeExternal}}
    external: true
{{- else}}
    driver: bridge
    ipam:
      config:
        - subnet: {{.EdgeSubnet}}
{{- end}}
{{- range .Tenants}}
  {{.Net}}:
    name: {{.Net}}
    driver: bridge
    ipam:
      config:
        - subnet: {{.Subnet}}
{{- end}}

services:
  vswarm-proxy:
    image: docker.angie.software/angie:latest
    container_name: vswarm-proxy
    restart: unless-stopped
    command: ["angie", "-g", "daemon off;"]
    volumes:
      - ./generated/angie/angie.conf:/etc/angie/angie.conf:ro
      - ./generated/angie/tenants:/etc/angie/tenants:ro
    networks:
      vswarm-edge:
        ipv4_address: {{.ProxyIP}}
{{- range .Tenants}}
      {{.Net}}: {}
{{- end}}
    security_opt:
      - no-new-privileges:true

{{- if .ManageTunnel}}
  vswarm-tunnel:
    image: cloudflare/cloudflared:latest
    container_name: vswarm-tunnel
    restart: unless-stopped
    command: ["tunnel", "--no-autoupdate", "run", "--token", "${VSWARM_TUNNEL_TOKEN}"]
    depends_on:
      - vswarm-proxy
    networks:
      - vswarm-edge
    security_opt:
      - no-new-privileges:true
{{- end}}
{{range .Tenants}}
  {{.Container}}:
    image: {{$.Image}}
    container_name: {{.Container}}
    restart: unless-stopped
    networks:
      - {{.Net}}
    environment:
      - T3CODE_HOME=/home/ai-agent/.config/t3
    volumes:
      - ./config/{{.Name}}/home:/home/ai-agent
    read_only: true
    tmpfs:
      - /tmp
      - /run
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    ulimits:
      nofile: 4096
    deploy:
      resources:
        limits:
          cpus: "{{$.CPUs}}"
          memory: {{$.Memory}}
          pids: {{$.Pids}}
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://127.0.0.1:3773/api/auth/session"]
      interval: 15s
      timeout: 5s
      retries: 10
      start_period: 40s
{{end}}
