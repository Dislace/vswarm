#!/usr/bin/env bash
# Manage workspace CLI releases without rebuilding or restarting the workspace.
#
# Tools are declared in a root-owned manifest. Releases are installed side by
# side, verified, then selected with an atomic symlink switch. A running CLI
# therefore keeps the release tree it started with while new processes use the
# selected version.

set -euo pipefail

tooling_root="${VSWARM_TOOLING_ROOT:-/opt/vswarm-tooling}"
manifest="${VSWARM_TOOLING_MANIFEST:-/etc/vswarm-tooling/tools.tsv}"
bin_dir="${VSWARM_TOOLING_BIN_DIR:-/usr/local/bin}"
workspace_home="${VSWARM_TOOLING_HOME:-/home/ai-agent}"
override_file="${workspace_home}/.config/vswarm-tooling/overrides.env"
release_root="${tooling_root}/releases"
lock_file="${tooling_root}/update.lock"
stage_dir=""
original_args=("$@")

declare -a tools=()
declare -A tool_source=()
declare -A tool_locator=()
declare -A tool_binary=()
declare -A tool_approved=()
declare -A tool_extras=()
declare -A claimed_binary=()
declare -A requested_versions=()

usage() {
  cat <<'EOF'
Usage:
  vswarm-tooling status [tool|all]
  vswarm-tooling update [tool|all]
  vswarm-tooling update <tool|all> --latest
  vswarm-tooling rollback [tool|all]

Normal updates select the approved versions in /etc/vswarm-tooling/tools.tsv.
`--latest` selects the newest upstream release and persists that choice in the
workspace home. `rollback` clears the selection and returns to the approved
version. Run `status all` to list the tools declared by the active manifest.
EOF
}

fail() {
  echo "vswarm-tooling: $*" >&2
  exit 1
}

valid_name() {
  [[ "$1" =~ ^[a-z][a-z0-9-]*$ ]]
}

valid_binary() {
  [[ "$1" =~ ^[A-Za-z0-9._+-]+$ ]]
}

valid_version() {
  [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.-]+)?$ ]]
}

load_manifest() {
  local raw line_no=0 name source locator binary version extras extra alias
  local -a aliases=() claimed=()
  [[ -r "${manifest}" ]] || fail "tool manifest not found: ${manifest}"
  while IFS= read -r raw || [[ -n "${raw}" ]]; do
    line_no=$((line_no + 1))
    raw="${raw%$'\r'}"
    [[ -z "${raw}" || "${raw}" == \#* ]] && continue
    IFS='|' read -r name source locator binary version extras extra <<<"${raw}"
    [[ -z "${extra:-}" ]] \
      || fail "${manifest}:${line_no}: expected six pipe-delimited fields"
    valid_name "${name:-}" \
      || fail "${manifest}:${line_no}: invalid tool name '${name:-}'"
    [[ -z "${tool_source[${name}]:-}" ]] \
      || fail "${manifest}:${line_no}: duplicate tool '${name}'"
    valid_binary "${binary:-}" \
      || fail "${manifest}:${line_no}: invalid binary '${binary:-}'"
    valid_version "${version:-}" \
      || fail "${manifest}:${line_no}: invalid version '${version:-}'"
    extras="${extras:--}"
    case "${source:-}" in
      npm)
        [[ "${locator:-}" =~ ^(@[A-Za-z0-9._-]+/)?[A-Za-z0-9._-]+$ ]] \
          || fail "${manifest}:${line_no}: invalid npm package '${locator:-}'"
        ;;
      go)
        [[ "${locator:-}" == go.dev ]] \
          || fail "${manifest}:${line_no}: Go tools must use the go.dev provider"
        ;;
      *)
        fail "${manifest}:${line_no}: unsupported provider '${source:-}'"
        ;;
    esac
    if [[ "${extras}" != "-" ]]; then
      IFS=',' read -ra aliases <<<"${extras}"
      for alias in "${aliases[@]}"; do
        valid_binary "${alias}" \
          || fail "${manifest}:${line_no}: invalid extra binary '${alias}'"
      done
    fi
    claimed=("${binary}")
    if [[ "${extras}" != "-" ]]; then
      claimed+=("${aliases[@]}")
    fi
    for alias in "${claimed[@]}"; do
      [[ -z "${claimed_binary[${alias}]:-}" ]] \
        || fail "${manifest}:${line_no}: binary '${alias}' already belongs to ${claimed_binary[${alias}]}"
      claimed_binary["${alias}"]="${name}"
    done
    tools+=("${name}")
    tool_source["${name}"]="${source}"
    tool_locator["${name}"]="${locator}"
    tool_binary["${name}"]="${binary}"
    tool_approved["${name}"]="${version}"
    tool_extras["${name}"]="${extras}"
  done <"${manifest}"
  [[ "${#tools[@]}" -gt 0 ]] || fail "${manifest}: no tools declared"
}

validate_target() {
  local target="$1" tool
  [[ "${target}" == all ]] && return
  for tool in "${tools[@]}"; do
    [[ "${target}" == "${tool}" ]] && return
  done
  fail "unknown tool '${target}'"
}

validate_override_file() {
  local raw name version extra line_no=0
  [[ -e "${override_file}" ]] || return 0
  [[ -r "${override_file}" ]] || fail "override file is not readable: ${override_file}"
  while IFS= read -r raw || [[ -n "${raw}" ]]; do
    line_no=$((line_no + 1))
    [[ -z "${raw}" ]] && continue
    IFS='=' read -r name version extra <<<"${raw}"
    [[ -z "${extra:-}" && -n "${tool_source[${name:-}]:-}" ]] \
      || fail "${override_file}:${line_no}: invalid or unknown tool override"
    valid_version "${version:-}" \
      || fail "${override_file}:${line_no}: invalid version '${version:-}'"
  done <"${override_file}"
}

override_version() {
  local wanted="$1" raw name version
  [[ -r "${override_file}" ]] || return 0
  while IFS= read -r raw || [[ -n "${raw}" ]]; do
    IFS='=' read -r name version <<<"${raw}"
    if [[ "${name}" == "${wanted}" ]]; then
      printf '%s\n' "${version}"
      return
    fi
  done <"${override_file}"
}

set_override() {
  local wanted="$1" selected="$2" directory pending raw name version owner=""
  directory="$(dirname "${override_file}")"
  pending="${override_file}.new.$$"
  mkdir -p "${directory}"
  : >"${pending}"
  if [[ -r "${override_file}" ]]; then
    while IFS= read -r raw || [[ -n "${raw}" ]]; do
      IFS='=' read -r name version <<<"${raw}"
      [[ "${name}" == "${wanted}" ]] || printf '%s\n' "${raw}" >>"${pending}"
    done <"${override_file}"
  fi
  if [[ -n "${selected}" ]]; then
    printf '%s=%s\n' "${wanted}" "${selected}" >>"${pending}"
  fi
  chmod 0644 "${pending}"
  if [[ "${EUID}" -eq 0 && -d "${workspace_home}" ]]; then
    owner="$(stat -c '%u:%g' "${workspace_home}")"
    chown "${owner}" "${directory}" "${pending}"
  fi
  mv -Tf "${pending}" "${override_file}"
}

clear_caught_up_overrides() {
  local tool override approved
  for tool in "${tools[@]}"; do
    override="$(override_version "${tool}")"
    approved="${tool_approved[${tool}]}"
    if [[ -n "${override}" ]] && ! version_gt "${override}" "${approved}"; then
      set_override "${tool}" ""
    fi
  done
}

version_gt() {
  local left="$1" right="$2"
  [[ "${left}" != "${right}" ]] \
    && [[ "$(printf '%s\n%s\n' "${left}" "${right}" | sort -V | tail -1)" == "${left}" ]]
}

desired_version() {
  local tool="$1" approved override
  if [[ -n "${requested_versions[${tool}]:-}" ]]; then
    printf '%s\n' "${requested_versions[${tool}]}"
    return
  fi
  approved="${tool_approved[${tool}]}"
  override="$(override_version "${tool}")"
  if [[ -n "${override}" ]] && version_gt "${override}" "${approved}"; then
    printf '%s\n' "${override}"
  else
    printf '%s\n' "${approved}"
  fi
}

remove_release_tree() {
  local path="$1"
  case "${path}" in
    "${release_root}"/*/.stage.*|"${release_root}"/*/*) ;;
    *) fail "refusing to remove unsafe release path ${path}" ;;
  esac
  [[ -d "${path}" ]] && find "${path}" -depth -delete
}

cleanup() {
  if [[ -n "${stage_dir}" && -d "${stage_dir}" ]]; then
    remove_release_tree "${stage_dir}"
  fi
}

atomic_link() {
  local target="$1" name="$2" pending
  pending="${bin_dir}/.${name}.vswarm-tooling.$$"
  if [[ -e "${pending}" || -L "${pending}" ]]; then
    unlink "${pending}"
  fi
  ln -s "${target}" "${pending}"
  mv -Tf "${pending}" "${bin_dir}/${name}"
}

release_version_from_link() {
  local tool="$1" binary resolved prefix remainder
  binary="${tool_binary[${tool}]}"
  resolved="$(readlink -f "${bin_dir}/${binary}" 2>/dev/null || true)"
  prefix="${release_root}/${tool}/"
  if [[ "${resolved}" == "${prefix}"* ]]; then
    remainder="${resolved#"${prefix}"}"
    printf '%s\n' "${remainder%%/*}"
  fi
}

reported_version() {
  local tool="$1" binary output=""
  binary="${tool_binary[${tool}]}"
  [[ -x "${bin_dir}/${binary}" ]] || return 0
  if [[ "${tool_source[${tool}]}" == go ]]; then
    output="$("${bin_dir}/${binary}" version 2>/dev/null || true)"
  else
    output="$("${bin_dir}/${binary}" --version 2>/dev/null || true)"
  fi
  grep -oE '[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.-]+)?' <<<"${output}" \
    | head -1 || true
}

current_version() {
  local version
  version="$(release_version_from_link "$1")"
  if [[ -n "${version}" ]]; then
    printf '%s\n' "${version}"
  else
    reported_version "$1"
  fi
}

status_one() {
  local tool="$1" current desired approved override channel state
  current="$(current_version "${tool}")"
  desired="$(desired_version "${tool}")"
  approved="${tool_approved[${tool}]}"
  override="$(override_version "${tool}")"
  channel=approved
  if [[ -n "${override}" ]] && version_gt "${override}" "${approved}"; then
    channel=latest
  fi
  state=stale
  if [[ "${current}" == "${desired}" ]]; then
    state=current
    [[ "${channel}" == latest ]] && state=ahead
  fi
  [[ -n "${current}" ]] || current=missing
  printf '%-10s installed=%-20s approved=%-20s selected=%-20s channel=%-8s %s\n' \
    "${tool}" "${current}" "${approved}" "${desired}" "${channel}" "${state}"
}

resolve_latest() {
  local tool="$1" source locator version=""
  source="${tool_source[${tool}]}"
  locator="${tool_locator[${tool}]}"
  case "${source}" in
    npm)
      version="$(npm view "${locator}" version)"
      ;;
    go)
      version="$(
        curl -fsSL 'https://go.dev/dl/?mode=json' \
          | python3 -c 'import json,sys
releases=json.load(sys.stdin)
stable=next((r["version"] for r in releases if r.get("stable")), "")
print(stable.removeprefix("go"))'
      )"
      ;;
  esac
  valid_version "${version}" || fail "could not resolve latest ${tool} version"
  printf '%s\n' "${version}"
}

verify_release() {
  local tool="$1" command_path="$2" want="$3" output got
  if [[ "${tool_source[${tool}]}" == go ]]; then
    output="$("${command_path}" version)"
  else
    output="$("${command_path}" --version)"
  fi
  got="$(grep -oE '[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.-]+)?' <<<"${output}" | head -1)"
  [[ "${got}" == "${want}" ]] \
    || fail "${tool} staged ${got:-unknown}; expected ${want}"
}

link_tool_binaries() {
  local tool="$1" release="$2" primary extras alias
  primary="${tool_binary[${tool}]}"
  atomic_link "${release}/bin/${primary}" "${primary}"
  extras="${tool_extras[${tool}]}"
  [[ "${extras}" == "-" ]] && return
  IFS=',' read -ra aliases <<<"${extras}"
  for alias in "${aliases[@]}"; do
    [[ -x "${release}/bin/${alias}" ]] \
      || fail "${tool} release does not contain declared binary ${alias}"
    atomic_link "${release}/bin/${alias}" "${alias}"
  done
}

install_npm_tool() {
  local tool="$1" version parent release command_path
  version="$(desired_version "${tool}")"
  parent="${release_root}/${tool}"
  release="${parent}/${version}"
  command_path="${release}/bin/${tool_binary[${tool}]}"
  if [[ ! -x "${command_path}" ]]; then
    mkdir -p "${parent}"
    [[ -e "${release}" ]] && remove_release_tree "${release}"
    stage_dir="${parent}/.stage.$$"
    [[ -e "${stage_dir}" ]] && remove_release_tree "${stage_dir}"
    npm install --global --prefix "${stage_dir}" --no-audit --no-fund \
      "${tool_locator[${tool}]}@${version}"
    verify_release "${tool}" "${stage_dir}/bin/${tool_binary[${tool}]}" "${version}"
    mv "${stage_dir}" "${release}"
    stage_dir=""
  fi
  link_tool_binaries "${tool}" "${release}"
}

archive_arch() {
  local arch=""
  if command -v dpkg >/dev/null 2>&1; then
    arch="$(dpkg --print-architecture)"
  else
    arch="$(uname -m)"
  fi
  case "${arch}" in
    amd64|x86_64) echo amd64 ;;
    arm64|aarch64) echo arm64 ;;
    *) fail "unsupported Go archive architecture ${arch}" ;;
  esac
}

go_file_metadata() {
  local version="$1" arch="$2"
  curl -fsSL 'https://go.dev/dl/?mode=json&include=all' \
    | python3 -c 'import json,sys
version, arch = sys.argv[1], sys.argv[2]
target = "go" + version
for release in json.load(sys.stdin):
    if release.get("version") != target:
        continue
    for item in release.get("files", []):
        if item.get("os") == "linux" and item.get("arch") == arch and item.get("kind") == "archive":
            print(item["filename"])
            print(item["sha256"])
            raise SystemExit(0)
raise SystemExit(1)' "${version}" "${arch}"
}

install_go_tool() {
  local tool="$1" version parent release arch filename checksum archive
  local -a metadata=()
  version="$(desired_version "${tool}")"
  parent="${release_root}/${tool}"
  release="${parent}/${version}"
  if [[ ! -x "${release}/bin/${tool_binary[${tool}]}" ]]; then
    mkdir -p "${parent}"
    [[ -e "${release}" ]] && remove_release_tree "${release}"
    stage_dir="${parent}/.stage.$$"
    [[ -e "${stage_dir}" ]] && remove_release_tree "${stage_dir}"
    mkdir -p "${stage_dir}"
    arch="$(archive_arch)"
    mapfile -t metadata < <(go_file_metadata "${version}" "${arch}")
    [[ "${#metadata[@]}" -eq 2 ]] \
      || fail "could not resolve checksum for Go ${version} linux/${arch}"
    filename="${metadata[0]}"
    checksum="${metadata[1]}"
    [[ "${filename}" =~ ^go[0-9A-Za-z.-]+\.linux-(amd64|arm64)\.tar\.gz$ ]] \
      || fail "go.dev returned an unsafe archive filename"
    [[ "${checksum}" =~ ^[0-9a-f]{64}$ ]] \
      || fail "go.dev returned an invalid archive checksum"
    archive="${stage_dir}/${filename}"
    curl -fsSL -o "${archive}" "https://go.dev/dl/${filename}"
    printf '%s  %s\n' "${checksum}" "${archive}" | sha256sum -c -
    tar -C "${stage_dir}" --strip-components=1 -xzf "${archive}"
    unlink "${archive}"
    verify_release "${tool}" "${stage_dir}/bin/${tool_binary[${tool}]}" "${version}"
    mv "${stage_dir}" "${release}"
    stage_dir=""
  fi
  link_tool_binaries "${tool}" "${release}"
}

release_in_use() {
  local release="$1" process exe
  for process in /proc/[0-9]*; do
    exe="$(readlink "${process}/exe" 2>/dev/null || true)"
    if [[ "${exe}" == "${release}/"* ]]; then
      return 0
    fi
    if [[ -r "${process}/cmdline" ]] \
      && grep -Fq "${release}/" "${process}/cmdline" 2>/dev/null; then
      return 0
    fi
  done
  return 1
}

prune_releases() {
  local tool="$1" current="$2" previous="$3" candidate version approved
  approved="${tool_approved[${tool}]}"
  for candidate in "${release_root}/${tool}"/*; do
    [[ -d "${candidate}" ]] || continue
    version="${candidate##*/}"
    [[ "${version}" == .stage.* ]] && continue
    if [[ "${version}" == "${current}" || "${version}" == "${previous}" \
      || "${version}" == "${approved}" ]]; then
      continue
    fi
    if release_in_use "${candidate}"; then
      echo "${tool}: retained in-use release ${version}"
    else
      remove_release_tree "${candidate}"
    fi
  done
}

update_one() {
  local tool="$1" before after
  before="$(current_version "${tool}")"
  case "${tool_source[${tool}]}" in
    npm) install_npm_tool "${tool}" ;;
    go) install_go_tool "${tool}" ;;
  esac
  after="$(current_version "${tool}")"
  prune_releases "${tool}" "${after}" "${before}"
  if [[ "${before}" == "${after}" ]]; then
    echo "${tool}: already ${after}"
  else
    echo "${tool}: ${before:-missing} -> ${after}"
  fi
}

case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
  '') usage; exit 2 ;;
esac

load_manifest
validate_override_file

[[ "$#" -le 3 ]] || fail "too many arguments"
command_name="${1:-}"
target="${2:-all}"
option="${3:-}"
case "${command_name}" in
  status|update|rollback) ;;
  *) fail "unknown command '${command_name}'" ;;
esac
validate_target "${target}"
case "${option}" in
  '') ;;
  --latest)
    [[ "${command_name}" == update ]] || fail "--latest is valid only with update"
    ;;
  *) fail "unknown option '${option}'" ;;
esac

if [[ "${EUID}" -ne 0 && "${tooling_root}" == /opt/vswarm-tooling ]]; then
  exec sudo "${0}" "${original_args[@]}"
fi

for path in "${tooling_root}" "${bin_dir}" "${workspace_home}"; do
  [[ "${path}" == /* && "${path}" != / ]] || fail "unsafe path ${path}"
done

selected_tools=("${tools[@]}")
if [[ "${target}" != all ]]; then
  selected_tools=("${target}")
fi

if [[ "${command_name}" == status ]]; then
  for tool in "${selected_tools[@]}"; do status_one "${tool}"; done
  exit 0
fi

mkdir -p "${tooling_root}" "${release_root}" "${bin_dir}"
exec 9>"${lock_file}"
flock -n 9 || fail "another update is already running"
trap cleanup EXIT INT TERM
clear_caught_up_overrides

if [[ "${command_name}" == rollback ]]; then
  for tool in "${selected_tools[@]}"; do set_override "${tool}" ""; done
fi

if [[ "${option}" == --latest ]]; then
  for tool in "${selected_tools[@]}"; do
    latest="$(resolve_latest "${tool}")"
    approved="${tool_approved[${tool}]}"
    if version_gt "${latest}" "${approved}"; then
      requested_versions["${tool}"]="${latest}"
    else
      requested_versions["${tool}"]="${approved}"
    fi
  done
fi

for tool in "${selected_tools[@]}"; do
  update_one "${tool}"
  if [[ "${option}" == --latest ]]; then
    if version_gt "${requested_versions[${tool}]}" "${tool_approved[${tool}]}"; then
      set_override "${tool}" "${requested_versions[${tool}]}"
    else
      set_override "${tool}" ""
    fi
  fi
done

if [[ "${option}" == --latest ]]; then
  requested_versions=()
  for tool in "${selected_tools[@]}"; do status_one "${tool}"; done
fi
