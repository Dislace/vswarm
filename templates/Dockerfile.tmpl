FROM node:24-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      git \
      ripgrep \
      openssh-client \
      curl \
      ca-certificates \
      python3 \
      make \
      g++ \
      sudo \
      util-linux \
      vim \
 && rm -rf /var/lib/apt/lists/*

# GitHub CLI — users run `gh auth login`; auth persists on their home volume.
RUN install -m 0755 -d /etc/apt/keyrings \
 && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
 && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
 && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
 && apt-get update && apt-get install -y --no-install-recommends gh \
 && rm -rf /var/lib/apt/lists/*

# T3 stays image-managed because loading an update requires restarting its
# server. Interactive CLIs are side-by-side releases managed independently.
RUN npm install -g t3@0.0.29-nightly.20260721.864 \
 && npm cache clean --force

COPY vswarm-tooling /usr/local/bin/vswarm-tooling
COPY tools.tsv /etc/vswarm-tooling/tools.tsv
RUN chmod 0755 /usr/local/bin/vswarm-tooling \
 && chmod 0644 /etc/vswarm-tooling/tools.tsv \
 && vswarm-tooling update all \
 && npm cache clean --force

RUN userdel -r node 2>/dev/null || true \
 && useradd -m -u 1000 -s /bin/bash ai-agent \
 && echo 'ai-agent ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/ai-agent \
 && chmod 0440 /etc/sudoers.d/ai-agent

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

COPY prompt.sh /tmp/prompt.sh
RUN cat /tmp/prompt.sh >> /etc/bash.bashrc && rm /tmp/prompt.sh

USER ai-agent
ENV T3CODE_HOME=/home/ai-agent/.config/t3
WORKDIR /home/ai-agent/repos

EXPOSE 3773
HEALTHCHECK --interval=15s --timeout=5s --retries=10 --start-period=40s \
  CMD curl -fsS http://127.0.0.1:3773/api/auth/session || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
