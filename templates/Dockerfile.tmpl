FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      git \
      ripgrep \
      openssh-client \
      curl \
      ca-certificates \
      python3 \
      make \
      g++ \
 && rm -rf /var/lib/apt/lists/*

RUN npm install -g \
      t3 \
      @anthropic-ai/claude-code \
      @openai/codex \
 && npm cache clean --force

RUN useradd -m -u 1000 -s /bin/bash ai-agent

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER ai-agent
ENV T3CODE_HOME=/home/ai-agent/.config/t3
WORKDIR /home/ai-agent/repos

EXPOSE 3773
HEALTHCHECK --interval=15s --timeout=5s --retries=10 --start-period=40s \
  CMD curl -fsS http://127.0.0.1:3773/api/auth/session || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
